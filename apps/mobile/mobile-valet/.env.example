EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_TIMEOUT=10000

# OAuth Configuration
# Add your OAuth client IDs here

# Google OAuth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# Microsoft OAuth  
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# Apple OAuth (configured in Xcode, no env variable needed for mobile)

# Dev
# EXPO_PUBLIC_API_URL=https://parkit-api-dev.onrender.com

# Prod
# EXPO_PUBLIC_API_URL=https://parkit-api-prod.onrender.com