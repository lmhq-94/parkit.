EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_TIMEOUT=10000

# =============================================================================
# OAuth Configuration for Mobile
# =============================================================================
# To enable OAuth, uncomment and fill the credentials. OAuth buttons only
# appear when these are configured.
#
# Google OAuth Setup:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 credentials for iOS and Android
# 3. For iOS: Bundle ID = com.parkit.valet
# 4. For Android: Package name = com.parkit.valet, SHA-1 fingerprint required
# 5. Copy the Web Client ID here
#
# Facebook OAuth Setup:
# 1. Go to https://developers.facebook.com/apps
# 2. Create new app → Select "Authenticate and request data from users with Facebook Login"
# 3. Add Facebook Login product
# 4. Configure Valid OAuth Redirect URIs: http://localhost:4000/auth/facebook/callback
# 5. Copy the App ID here

# Google OAuth (required for Google Sign-In button)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Facebook OAuth (required for Facebook Sign-In button)
# EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Microsoft OAuth - Not yet implemented for mobile

# =============================================================================
# Environment URLs
# =============================================================================

# Dev
# EXPO_PUBLIC_API_URL=https://parkit-api-dev.onrender.com

# Prod
# EXPO_PUBLIC_API_URL=https://parkit-api-prod.onrender.com