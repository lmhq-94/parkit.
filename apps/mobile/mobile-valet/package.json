    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@shopify/react-native-skia": "2.2.12",
    "@stripe/stripe-react-native": "0.50.3",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "axios": "1.7.7",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
