  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:fast": "EXPO_USE_METRO_WORKER_THREADS=1 expo start --clear",
    "start:reset": "expo start --reset-cache",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform android --platform ios",
    "eject": "expo eject",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "generate-native": "expo prebuild --clean"
