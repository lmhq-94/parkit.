EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_TIMEOUT=10000

# Dev
# EXPO_PUBLIC_API_URL=https://parkit-api-dev.onrender.com

# Prod
# EXPO_PUBLIC_API_URL=https://parkit-api-prod.onrender.com

# =============================================================================
# OAuth Configuration (Uncomment to enable)
# =============================================================================

# Google OAuth - Get from https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID for iOS/Android
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Facebook OAuth - Get from https://developers.facebook.com/apps
# EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Microsoft OAuth - Get from https://portal.azure.com/ > App registrations
# EXPO_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id