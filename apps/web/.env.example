# API Configuration (backend runs at :4000 with routes /users, /auth, etc. — no /api prefix)
NEXT_PUBLIC_API_URL=http://localhost:4000

# El selector de dirección (empresas y estacionamientos) usa Leaflet + OpenStreetMap (sin API key).

# Authentication
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Optional: app version shown in sidebar (defaults to package.json "version" at build time)
# NEXT_PUBLIC_APP_VERSION=1.2.0

# Optional: For production
# NEXT_PUBLIC_API_URL=https://api.parkit.prod/api
# NEXTAUTH_URL=https://admin.parkit.prod
