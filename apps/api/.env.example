PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret"

# Invitation emails (optional: leave unset to log invite links to console)
# INVITATION_BASE_URL="https://your-web-app.com"   # Base URL for accept-invite links (default: http://localhost:3000)
# RESEND_API_KEY=re_xxx                            # Resend.com API key to send emails
# INVITATION_FROM_EMAIL="Parkit <noreply@yourdomain.com>"

# Vehicle catalog: automatic dimensions (length/width/height) by make+model+year
# Option 1: API Ninjas — https://api-ninjas.com (endpoint /v1/cars)
# API_NINJAS_KEY=
# Option 2: Car Specs (RapidAPI) — https://rapidapi.com/alekivanovski96-O1vKHrFskQm/api/car-specs
# CAR_SPECS_RAPIDAPI_KEY=
