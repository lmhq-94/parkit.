# =============================================================================
# Parkit API – Environment variables (example)
# =============================================================================
# Copy this file to .env.development or .env.production and fill in the values.
# Then run: npm run env:dev (development) or npm run env:prod (production)
# to copy the active file to .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Example Neon: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# Required. Generate one with: openssl rand -hex 32
# Use a different value in development and production.
JWT_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Invitation emails (Resend)
# -----------------------------------------------------------------------------
# Without RESEND_API_KEY, invitation links are only printed to the console (useful in dev).
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Support email used in email footer; should match login/support links (e.g. soporte@parkitcr.com)
SUPPORT_EMAIL=soporte@parkitcr.com

# Invitation emails (Admin invitation)
# Email "from" address. In development you can use: "Parkit <onboarding@resend.dev>"
# In production use a domain verified in Resend, e.g. "Parkit <noreply@yourdomain.com>"
INVITATION_FROM_EMAIL="Parkit <noreply@yourdomain.com>"
# Base URL of the frontend where the user accepts the invitation (no domain yet → localhost)
INVITATION_BASE_URL="http://localhost:3000"
# Template ID configured in Resend dashboard
INVITATION_TEMPLATE_ID=parkit-admin-invite
# Optional URLs for invitation email footer
INVITATION_PRIVACY_URL="http://localhost:3000/privacy"
INVITATION_TERMS_URL="http://localhost:3000/terms"
INVITATION_UNSUBSCRIBE_URL="http://localhost:3000/unsubscribe"

# Ticket Code emails (Parking ticket codes)
# Email "from" address for ticket codes
TICKET_CODE_FROM_EMAIL="Parkit <noreply@yourdomain.com>"
# Template ID configured in Resend dashboard
TICKET_CODE_TEMPLATE_ID=parkit-ticket-code
TICKET_CODE_PRIVACY_URL="http://localhost:3000/privacy"
TICKET_CODE_TERMS_URL="http://localhost:3000/terms"
TICKET_CODE_UNSUBSCRIBE_URL="http://localhost:3000/unsubscribe"

# -----------------------------------------------------------------------------
# OAuth Configuration (Google, Microsoft, Apple)
# -----------------------------------------------------------------------------

# Google OAuth
# Get from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Microsoft OAuth
# Get from Azure Portal: https://portal.azure.com/ > App registrations
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:4000/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# Facebook OAuth
# Get from Meta for Developers: https://developers.facebook.com/apps
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:4000/auth/facebook/callback

# Apple Sign-In (Web)
# Requires Apple Developer account with Sign In with Apple capability
# For web: needs client secret JWT generation (complex setup)
# For mobile: handled by @invertase/react-native-apple-authentication

# Frontend URL for OAuth callbacks
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Other (no variables required)
# -----------------------------------------------------------------------------
# Vehicle catalog (brands, models, dimensions): uses CarQuery API;
# no environment variables need to be set.
