# =============================================================================
# Parkit API – Environment variables (example)
# =============================================================================
# Copy this file to .env.development or .env.production and fill in the values.
# Then run: npm run env:dev (development) or npm run env:prod (production)
# to copy the active file to .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Example Neon: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# Required. Generate one with: openssl rand -hex 32
# Use a different value in development and production.
JWT_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Invitation emails (Resend)
# -----------------------------------------------------------------------------
# Without RESEND_API_KEY, invitation links are only printed to the console (useful in dev).
# API key: https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email "from" address. In development you can use: "Parkit <onboarding@resend.dev>"
# In production use a domain verified in Resend, e.g. "Parkit <noreply@yourdomain.com>"
INVITATION_FROM_EMAIL="Parkit <noreply@yourdomain.com>"
# Base URL of the frontend where the user accepts the invitation (e.g. https://admin.parkit.com)
INVITATION_BASE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Other (no variables required)
# -----------------------------------------------------------------------------
# Vehicle catalog (brands, models, dimensions): uses CarQuery API;
# no environment variables need to be set.
